{
  "name": "expo-push-easy",
  "version": "1.0.2",
  "description": "Send push notifications from any JS runtime — FCM v1, zero painful config",
  "repository": "yoh-space/expo-push-easy",
  "homepage": "https://github.com/yoh-space/expo-push-easy#readme",
  "bugs": "https://github.com/yoh-space/expo-push-easy/issues",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "expo",
    "push",
    "notification",
    "fcm",
    "firebase",
    "react-native"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "tsup": {
    "entry": {
      "index": "src/index.ts"
    },
    "format": [
      "esm",
      "cjs"
    ],
    "dts": true,
    "clean": true
  },
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {}
}
